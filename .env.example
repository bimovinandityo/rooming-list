# MongoDB — leave unset to use the in-memory store (dev only)
# DATABASE_URL=

# OpenAI — required for the AI agent
OPENAI_API_KEY=

# GraphQL API — used by codegen (build time) and the client (runtime)
GRAPHQL_ENDPOINT=https://api.example.com/graphql
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://api.example.com/graphql

# App metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# Client identification
NEXT_PUBLIC_CLIENT_NAME=rooming-list
NEXT_PUBLIC_CLIENT_VERSION=0.1.0
